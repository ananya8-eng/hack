# Copy to .env and fill in your values:
#   cp .env.example .env

API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=*

NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

GROK_API_KEY=
XAI_API_KEY=
GROK_API_BASE_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-2-latest

HUGGINGFACE_API_KEY=
HF_TOKEN=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-3B-Instruct
HUGGINGFACE_INFERENCE_URL=

GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

LLM_DEFAULT_TIMEOUT=90

USE_MOCK_EMBEDDINGS=false
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
CHROMA_DB_PATH=./chroma_db
PRELOAD_EMBEDDINGS_ON_STARTUP=true
MAX_CHUNKS_PER_SECTION=80
MAX_CHUNKS_PER_FILING=250
MAP_ANALYSIS_CHUNK_CHARS=3500
MAX_MAP_PASSES=24

SEC_EDGAR_COMPANY_NAME=AegisFinancialAgent
SEC_EDGAR_EMAIL=your-email@example.com
SCRAPED_FILINGS_DIR=./scraped_filings
SCRAPER_USER_AGENT=Mozilla/5.0 AegisFinancialAgent/1.0
