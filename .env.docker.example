# Copy to .env for local Docker: cp .env.docker.example .env
# Embedding runs on a REMOTE host — set your ngrok/public URL here (not localhost).

API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Remote embedding service (required for production)
EMBEDDING_SERVICE_URL=https://your-embedding-host.example.com
EMBEDDING_SERVICE_API_KEY=your-embedding-api-key
EMBEDDING_SERVICE_MODE=qdrant
EMBEDDING_SERVICE_PATH=/embed
EMBEDDING_QUERY_PATH=/query
USE_MOCK_EMBEDDINGS=false

# Qdrant Cloud (backend searches; embedding host upserts)
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# LLM (at least one)
NVIDIA_API_KEY=
SEC_EDGAR_EMAIL=you@example.com
SEC_EDGAR_COMPANY_NAME=YourOrgName

# Frontend build arg (browser → host-mapped API)
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_PIPELINE_POLL_TIMEOUT_MS=900000
